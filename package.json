{
  "name": "starcraft-tmg-bot",
  "version": "1.0.0",
  "description": "Discord bot and web UI for StarCraft TMG army roster lookup",
  "type": "module",
  "scripts": {
    "start": "node web/server.js",
    "bot": "node bot/bot.js",
    "build:hosting": "node scripts/build-pages.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "web": "node web/server.js",
    "deploy:hosting": "npm run build:hosting && npx firebase-tools deploy --only hosting",
    "deploy": "node bot/deploy-commands.js",
    "test": "node tests/run.mjs",
    "test:capture": "node tests/capture-fixtures.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase": "^12.12.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.0",
    "puppeteer": "24.40.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
