# ── Discord bot credentials ───────────────────────────────────────────────────
# Obtain from https://discord.com/developers/applications → Your App → Bot
DISCORD_TOKEN=your_bot_token_here

# Your app's Application (Client) ID (General Information page)
DISCORD_CLIENT_ID=your_client_id_here

# Optional: a specific Guild (server) ID for instant command registration during dev.
# Remove or leave blank to register global commands (takes up to 1 hour to propagate).
DISCORD_GUILD_ID=your_guild_id_here

# ── Web server ────────────────────────────────────────────────────────────────
# Port for the web UI / API server (default: 3000)
PORT=3000

# ── Traffic analytics (optional) ──────────────────────────────────────────────
# Set a key to protect /api/analytics. If empty, endpoint is open.
ANALYTICS_KEY=

# Internal key used by the bot when posting /roster invoke telemetry to web analytics.
# If blank, ANALYTICS_KEY is used.
ANALYTICS_INTERNAL_KEY=

# Path inside container where analytics data is persisted.
ANALYTICS_FILE=/app/data/analytics.json

# Daily analytics email report (optional)
ANALYTICS_EMAIL_TO=jaredtritsch@gmail.com
ANALYTICS_EMAIL_FROM=
ANALYTICS_DAILY_REPORT_UTC_HOUR=13

# SMTP settings for daily report email
ANALYTICS_SMTP_HOST=
ANALYTICS_SMTP_PORT=587
ANALYTICS_SMTP_SECURE=false
ANALYTICS_SMTP_USER=
ANALYTICS_SMTP_PASS=
