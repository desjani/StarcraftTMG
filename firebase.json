{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist/pages",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/StarcraftTMG",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/StarcraftTMG/**",
        "destination": "/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/mobile",
        "destination": "/mobile/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}